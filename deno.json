{
  "nodeModulesDir": "auto",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "test": "deno test --allow-all",
    "prisma:generate": "deno run -A --env-file npm:prisma generate",
    "prisma:migrate": "deno run -A --env-file npm:prisma migrate dev",
    "prisma:studio": "deno run -A --env-file npm:prisma studio"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*",
    "lib/generated/**"
  ],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "zod": "npm:zod@^3.24",
    "@logtape/logtape": "jsr:@logtape/logtape@^0.12",
    "prisma": "npm:prisma@^7",
    "@prisma/client": "npm:@prisma/client@^7",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7",
    "pg": "npm:pg@^8",
    "@types/node": "npm:@types/node@^22",
    "@std/assert": "jsr:@std/assert@^1",
    "@scoundrel/engine": "./lib/engine/mod.ts",
    "@scoundrel/game": "./lib/scoundrel/mod.ts",
    "@scoundrel/game-service": "./lib/game/mod.ts"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "deploy": {
    "org": "ever-forward",
    "app": "scoundrel"
  },
  "allowScripts": ["npm:@prisma/engines", "npm:prisma"]
}
