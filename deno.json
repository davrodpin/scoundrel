{
  "nodeModulesDir": "auto",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "test": "deno test --allow-all",
    "test:unit": "deno test --allow-all --ignore=lib/*/tests/,tests/",
    "test:integration": "deno test --allow-all tests/",
    "prisma:generate": "deno run -A --env-file npm:prisma generate",
    "prisma:migrate": "deno run -A --env-file npm:prisma migrate deploy",
    "prisma:studio": "deno run -A --env-file npm:prisma studio",
    "optimize:cards": "deno run --allow-read --allow-write --allow-env --allow-run --allow-ffi scripts/optimize-cards.ts",
    "worktree:setup": "deno run --allow-run --allow-read --allow-write .claude/skills/git-workflow/scripts/worktree_setup.ts",
    "worktree:cleanup": "deno run --allow-run --allow-read .claude/skills/git-workflow/scripts/worktree_cleanup.ts",
    "audit:game": "deno run --allow-net --allow-env --allow-read scripts/audit-game.ts",
    "repair:stuck-games": "deno run --allow-net --allow-env --allow-read scripts/game-stuck/repair-stuck-games.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*",
    "lib/generated/**"
  ],
  "fmt": {
    "lineWidth": 80
  },
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "zod": "npm:zod@^3.24",
    "@logtape/logtape": "jsr:@logtape/logtape@^0.12",
    "@logtape/otel": "jsr:@logtape/otel@^2",
    "prisma": "npm:prisma@^7",
    "@prisma/client": "npm:@prisma/client@^7",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7",
    "@types/node": "npm:@types/node@^22",
    "@types/pg": "npm:@types/pg@^8",
    "pg": "npm:pg@^8",
    "@types/node": "npm:@types/node@^22",
    "@std/assert": "jsr:@std/assert@^1",
    "@scoundrel/config": "./lib/config/mod.ts",
    "@scoundrel/engine": "./lib/engine/mod.ts",
    "@scoundrel/errors": "./lib/errors/mod.ts",
    "@scoundrel/game": "./lib/scoundrel/mod.ts",
    "@scoundrel/game-service": "./lib/game/mod.ts",
    "@scoundrel/log-format": "./lib/log-format/mod.ts",
    "@scoundrel/cleanup": "./lib/cleanup/mod.ts",
    "@scoundrel/validation": "./lib/validation/mod.ts",
    "@scoundrel/telemetry": "./lib/telemetry/mod.ts",
    "@scoundrel/feedback": "./lib/feedback/mod.ts",
    "obscenity": "npm:obscenity@^0.4.6",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "deploy": {
    "org": "ever-forward",
    "app": "scoundrel"
  },
  "allowScripts": {
    "allow": [
      "npm:@prisma/client@7.3.0",
      "npm:@prisma/engines@7.3.0",
      "npm:prisma@7.3.0",
      "npm:sharp@0.33.5",
      "npm:@img/sharp-darwin-arm64@0.33.5",
      "npm:@img/sharp-libvips-darwin-arm64@1.0.4"
    ],
    "deny": [
      "npm:esbuild@0.25.12",
      "npm:esbuild@0.25.7",
      "npm:esbuild@0.27.3",
      "npm:fsevents@2.3.3"
    ]
  }
}
