# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# Required
# PostgreSQL connection string used by Prisma to connect to the database
DATABASE_URL=

# Optional — defaults shown
# Base URL of the app, used for CORS allowed origin
# APP_ORIGIN=https://scoundrel.gg
# Maximum allowed request body size in bytes
# MAX_BODY_BYTES=4096
# Maximum number of characters allowed in a player name
# MAX_PLAYER_NAME_LENGTH=30
# Player name used when none is provided
# DEFAULT_PLAYER_NAME=Anonymous
# Number of top scores shown on the leaderboard
# LEADERBOARD_LIMIT=25
# Number of days to retain completed game records before automatic deletion
# GAME_RETENTION_DAYS=30
# Deno Deploy deployment ID, injected automatically in production
# DENO_DEPLOYMENT_ID=
